# Standalone dev configuration — copy to hem/.env (gitignored).
# Under the Supervisor none of this is needed: the add-on gets its connection
# and timezone from the Supervisor, and the config UI writes /data/hem-config.json.

# Home Assistant connection (long-lived access token: HA profile -> Security)
HEM_HA_URL=http://homeassistant.local:8123
HEM_HA_TOKEN=

# Local timezone (IANA name). Anchors the learned load buckets, the daily SoC
# target and vacation end times; without it (or TZ in the environment) HEM
# runs in UTC and every local-time feature is shifted by your UTC offset.
HEM_TZ=Australia/Adelaide

# Optional overrides
#HEM_LOG_LEVEL=debug
#HEM_CONFIG_FILE=./hem-config.json
